namespace feedback

README: Doc
README = {{
    # Feedback Application

        This project demonstrates how to create a little application that can
        receive feedback.

        It is a web service where people can send jsonified {type Doc}s to,
        that get stored in a database.

        ```mermaid
sequenceDiagram
  Note left of Booster: Sends Feedback
  Booster->>Server: Doc
  Note right of Server: Receives Feedback
  Server->>Booster: 👍
        ```
}}


logic.receive : '{Route, Exception}()
logic.receive = do
    noCapture POST (s "feedback")
    match (catch do
        text = bodyUtf8()
        Json.fromText text) with
            Right json ->
                match Doc.fromJson json with
                    Right doc ->
                        ok.json (Object [("state", Text "successful"), ("message", Text "Thank you for your feedback")])

                    Left failure ->
                        raiseBadRequest "failed to parse Doc" failure

            Left failure ->
                raiseBadRequest "failed to parse json" failure


    
---

logic : '{Route}()
logic = 
    use Route <|>
    logic.info <|> logic.receive

logic.info : '{Route}()
logic.info = do
    noCapture GET (s "feedback")
    ok.text "You can send feedback via a POST request"

logic.receive : '{Route}()
logic.receive = do
    noCapture POST (s "feedback")
    ok.json (Object [("state", Text "successful"), ("message", Text "Thank you for your feedback")])
    

deploy : '{IO, Exception} URI
deploy = 
    Cloud.main do
        serviceHash = deployHttp Environment.default() (run feedback.logic)
        ServiceName.assign (ServiceName.named "booster-unison-feedback") serviceHash


deployLocal : '{IO, Exception} ()
deployLocal = do
    stop = serveSimple feedback.logic 5683
    printLine "Server running on port 5683. Press <enter> to stop."
    _ = readLine()
    stop()
    
---

service : HttpRequest -> HttpResponse
service _ =
    HttpResponse.ok (Body (Text.toUtf8 "Thank you for your feedback"))


deploy : '{IO, Exception} URI
deploy = 
    Cloud.main do
        serviceHash = deployHttp Environment.default() feedback.service
        ServiceName.assign (ServiceName.named "booster-unison-feedback") serviceHash
        
