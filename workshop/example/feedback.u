

namespace feedback

README : Doc
README =
  {{
  # Feedback Application
  
    This project demonstrates how to create a little application that can
    receive feedback.
    
    It is a web service where people can send jsonified {type Doc}s to, that
    get stored in a database.
    
    ``` mermaid
    sequenceDiagram
    Note left of Booster: Sends Feedback
    Booster->>Server: Doc
    Note right of Server: Receives Feedback
    Server->>Booster: 👍
    ```

  ## Project

    If you like you could write a Unison function that sends {feedback}
    {type Doc} to
    
    ```plain
     https://dvberkel.unison-services.cloud/s/booster-unison-feedback/feedback/
    ```
  }}



---



namespace feedback

logic : OrderedTable Instant Doc -> '{Route, Exception, Remote} ()
logic table =
  use Route <|>
  logic.info table <|> logic.receive table <|> logic.retrieve table <|> logic.remove table

logic.remove : OrderedTable Instant Doc -> '{Route, Remote} ()
logic.remove table = do
    use Parser /
    instant = route DELETE (
        (s "feedback" / Parser.int / Parser.nat)
            => cases seconds, nanos -> Instant seconds nanos)
    OrderedTable.delete table instant
    ok.json (Object
        [ ("state", Text "successful")
        , ("message", Text "removed feedback")
        , ("instant", Instant.toJson instant)]) 
---

logic.info : OrderedTable Instant Doc -> '{Route, Remote} ()
logic.info table = do
    noCapture GET (s "feedback")
    table
        |> OrderedTable.toStream
        |> Stream.toList
        |> List.map (at1 >> Instant.toJson)
        |> Array
        |> ok.json

Instant.toJson : Instant -> Json
Instant.toJson = cases
    Instant seconds nanoSeconds ->
        Object
            [ ("tag", Text "Instant")
            , ("seconds", Number (Int.toText seconds))
            , ("nano", Number (Nat.toText nanoSeconds))
            ]

logic.retrieve : OrderedTable Instant Doc -> '{Route, Remote, Exception} ()
logic.retrieve table = do
    use Parser /
    instant = route GET (
        (s "feedback" / Parser.int / Parser.nat )
            => cases seconds, nanos -> Instant seconds nanos)
    doc = OrderedTable.read table instant
    ok.json (Doc.toJson doc)

logic.receive :
  OrderedTable Instant Doc -> '{Route, Exception, Remote} ()
logic.receive table =
  do
    noCapture POST (s "feedback")
    match 
      catch do
        text = bodyUtf8()
        Json.fromText text
     with
      Right json ->
        match Doc.fromJson json with
          Right doc ->
            tick = Remote.now()
            OrderedTable.write table tick doc
            ok.json
              (Object
                [ ("state", Text "successful")
                , ("message", Text "Thank you for your feedback")
                , ("instant", Instant.toJson tick)])
          Left failure -> raiseBadRequest "failed to parse Doc" failure
      Left failure -> raiseBadRequest "failed to parse json" failure



