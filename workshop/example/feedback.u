test> Doc.fromJson.tests.roundTrip = test.verify do
    [ feedback
    , 
        {{ # Test Document

            This should survive the round trip

            ```plain
            >  echo "Hello, World!"
            ```
        }}    
    ]
        |> List.foreach Doc.fromJson.tests.harness

---

Doc.fromJson.tests.harness : Doc ->{Exception} ()
Doc.fromJson.tests.harness original =
    actual =
        original
            |> Doc.toJson
            |> Doc.fromJson
    match actual with
        Right rehydrated | rehydrated === original -> ()
        Right rehydrated -> test.raiseFailure "did not survive roundtrip" (original, rehydrated)
        Left failure -> test.raiseFailure "failed to rehydrate" failure

Doc.fromJson.boolean : Json -> Either Doc.fromJson.Failure Boolean
Doc.fromJson.boolean = cases
    Boolean context ->
        Right context

    context ->
        Left (NotAn "Boolean" context)
                        
Doc.fromJson.text : Json -> Either Doc.fromJson.Failure Text
Doc.fromJson.text = cases
    Text context ->
        Right context

    context ->
        Left (NotAn "Text" context)

Doc.fromJson.number : Json -> Either Doc.fromJson.Failure Nat
Doc.fromJson.number = cases
    Number source ->
        match Nat.fromText source with
            Some n -> Right n

            None ->
                Left (Failure.NotANat source)

    context ->
        Left (NotAn "Number" context)

Doc.fromJson.optional : (Json -> Either Doc.fromJson.Failure a) -> Json -> Either Doc.fromJson.Failure (Optional a)
Doc.fromJson.optional construct context =
    match context with
        Object keys ->
            match ifPresent "tag" keys with
                Some (Text "Optional") ->
                    match ifPresent "kind" keys with
                        Some (Text "None") -> 
                            Right None

                        Some (Text "Some") ->
                            match ifPresent "value" keys with
                                Some json ->
                                    json
                                        |> construct
                                        |> Either.mapRight (Some)

                                None ->
                                   Left (MissingValue context)         

                        Some json ->
                            Left (UnknownKind json)

                        None ->
                            Left (MissingKey "kind")

                _ ->
                    Left (NotAn "Optional" context)

        _ ->
            Left (NotAn "Object" context)

Doc.fromJson.list : (Json -> Either Doc.fromJson.Failure a) -> Json -> Either Doc.fromJson.Failure (List a)
Doc.fromJson.list construct context =
    match context with
        Array elements ->
            candidates =
                elements
                    |> List.map construct
            if List.all isRight candidates then
                candidates
                    |> List.map Either.toBug
                    |> Right
            else
                candidates
                    |> List.indexed
                    |> List.filterMap
                        ( cases
                            (Left a, n) -> Some (a,n)
                            _ -> None

                        )
                    |> ListFailures context
                    |> Left

        _ ->
            Left (NotAn "Array" context)

type Doc.fromJson.Failure
    = NotAn Text Json
    | MissingTag
    | UnknownTag Json
    | MissingValue Json
    | MissingKey Text
    | UnknownKind Json
    | ListFailures Json [(Doc.fromJson.Failure, Nat)]
    | NotANat Text

Doc.fromJson : Json -> Either Doc.fromJson.Failure Doc
Doc.fromJson json =
    match json with
        Object keys ->
            at : Text -> (Json -> Either Doc.fromJson.Failure a) -> Either Doc.fromJson.Failure (a -> b) -> Either Doc.fromJson.Failure b
            at key extract transform =
                match ifPresent key keys with
                    Some json ->
                        json
                            |> extract
                            |> thenApply transform
                        
                    None ->
                        Left (MissingKey key)

            thenApply : Either a (b -> c) -> Either a b -> Either a c
            thenApply v u =
                match (u, v) with
                    (Right a, Right f) -> Right (f a)
                    (Right a, Left a') -> Left a'
                    (Left a, _) -> Left a


            succeed : a -> Either Doc.fromJson.Failure a
            succeed =
                Right


            match ifPresent "tag" keys with
                Some (Text "Blankline") ->
                    Blankline
                        |> succeed
                
                Some (Text "Linebreak") ->
                    Linebreak
                        |> succeed
                
                Some (Text "SectionBreak") ->
                    SectionBreak
                        |> succeed
                        
                Some (Text "Word") ->
                    Word
                        |> succeed
                        |> at "value" fromJson.text
                
                Some (Text "Code") ->
                    Code
                        |> succeed
                        |> at "value" Doc.fromJson
                                    
                Some (Text "Bold") ->
                    Bold
                        |> succeed
                        |> at "value" Doc.fromJson
                
                Some (Text "Italic") ->
                    Italic
                        |> succeed
                        |> at "value" Doc.fromJson
                                    
                Some (Text "Strikethrough") ->
                    Strikethrough
                        |> succeed
                        |> at "value" Doc.fromJson
                
                Some (Text "Blockquote") ->
                    Blockquote
                        |> succeed
                        |> at "value" Doc.fromJson
                                    
                Some (Text "Aside") ->
                    Aside
                        |> succeed
                        |> at "value" Doc.fromJson
                
                Some (Text "Group") ->
                    Group
                        |> succeed
                        |> at "value" Doc.fromJson

                Some (Text "CodeBlock") ->
                    CodeBlock
                        |> succeed
                        |> at "language" fromJson.text
                        |> at "value" Doc.fromJson
                                                            
                Some (Text "Style") ->
                    Style
                        |> succeed
                        |> at "class" fromJson.text
                        |> at "value" Doc.fromJson
                                                            
                Some (Text "Anchor") ->
                    Anchor
                        |> succeed
                        |> at "identifier" fromJson.text
                        |> at "value" Doc.fromJson
                
                Some (Text "Tooltip") ->
                    Tooltip
                        |> succeed
                        |> at "value" Doc.fromJson
                        |> at "hint" fromJson
                                                            
                Some (Text "NamedLink") ->
                    NamedLink
                        |> succeed
                        |> at "value" Doc.fromJson
                        |> at "url" Doc.fromJson
                                                            
                Some (Text "Folded") ->
                    Folded
                        |> succeed
                        |> at "folded" fromJson.boolean
                        |> at "title" Doc.fromJson
                        |> at "value" Doc.fromJson
                                                            
                Some (Text "Callout") ->
                    Callout
                        |> succeed
                        |> at "icon" (fromJson.optional Doc.fromJson)
                        |> at "value" Doc.fromJson

                Some (Text "Image") ->
                    Image
                        |> succeed
                        |> at "value" Doc.fromJson
                        |> at "url" Doc.fromJson
                        |> at "caption" (fromJson.optional Doc.fromJson)

                Some (Text "Paragraph") ->
                    Paragraph
                        |> succeed
                        |> at "value" (fromJson.list Doc.fromJson)

                Some (Text "BulletedList") ->
                    BulletedList
                        |> succeed
                        |> at "value" (fromJson.list Doc.fromJson)

                Some (Text "Join") ->
                    Join
                        |> succeed
                        |> at "value" (fromJson.list Doc.fromJson)
                
                Some (Text "UntitledSection") ->
                    UntitledSection
                        |> succeed
                        |> at "value" (fromJson.list Doc.fromJson)

                Some (Text "Column") ->
                    Column
                        |> succeed
                        |> at "value" (fromJson.list Doc.fromJson)

                Some (Text "NumberedList") ->
                    NumberedList
                        |> succeed
                        |> at "index" fromJson.number
                        |> at "value" (fromJson.list Doc.fromJson)

                Some (Text "Section") ->
                    Section
                        |> succeed
                        |> at "title" Doc.fromJson
                        |> at "value" (fromJson.list Doc.fromJson)

                Some (Text "Special") ->
                    Word
                        |> succeed
                        |> at "comment" fromJson.text

                Some (Text "Table") ->
                    Table
                        |> succeed
                        |> at "value" (fromJson.list (fromJson.list Doc.fromJson))
                
                Some v ->
                    Left (UnknownTag v)

                None ->
                    Left (MissingTag)
        _ ->
            Left (NotAn "Object" json)



