Doc.fromJson.tests.harness.fromJsonShouldProduce : Json -> Doc ->{Exception} ()
Doc.fromJson.tests.harness.fromJsonShouldProduce subject expected =
    actual = Doc.fromJson subject

    ensureEqual actual (Right expected)

---

ifPresent : a -> List (a, b) -> Optional b
ifPresent target = cases
    (key, value) +: _ | key === target -> Some value
    _ +: rest -> ifPresent target rest
    _ -> None

test> ifPresent.tests.ex1 = test.verify do
    actual = ifPresent "a" [("a", 0), ("a", 1)] 
    expected = Some 0
    ensureEqual actual expected

test> ifPresent.tests.ex2 = test.verify do
    actual = ifPresent "b" [("a", 0), ("b", 1)] 
    expected = Some 1
    ensureEqual actual expected

test> ifPresent.tests.ex3 = test.verify do
    actual = ifPresent "c" [("a", 0), ("b", 1)] 
    expected = None
    ensureEqual actual expected

---

Doc.toJson : Doc -> Json
Doc.toJson doc =
    match doc with
        Blankline ->
            Object
                [ ("tag", Text "Blankline")
                ]
        Linebreak ->
            Object
                [ ("tag", Text "Linebreak")
                ]
        SectionBreak ->
            Object
                [ ("tag", Text "SectionBreak")
                ]
        Code doc ->
            Object
                [ ("tag", Text "Code")
                , ("value", Doc.toJson doc)
                ]
        Doc.Bold doc ->
            Object
                [ ("tag", Text "Bold")
                , ("value", Doc.toJson doc)
                ]
        Italic doc ->
            Object
                [ ("tag", Text "Italic")
                , ("value", Doc.toJson doc)
                ]
        Strikethrough doc ->
            Object
                [ ("tag", Text "Strikethrough")
                , ("value", Doc.toJson doc)
                ]
        Blockquote doc ->
            Object
                [ ("tag", Text "Blockquote")
                , ("value", Doc.toJson doc)
                ]
        Aside doc ->
            Object
                [ ("tag", Text "Aside")
                , ("value", Doc.toJson doc)
                ]
        Doc.Group doc ->
            Object
                [ ("tag", Text "Group")
                , ("value", Doc.toJson doc)
                ]
        CodeBlock language doc ->
            Object
                [ ("tag", Text "CodeBlock")
                , ("language", Text language)
                , ("value", Doc.toJson doc)
                ]
        Style class doc ->
            Object
                [ ("tag", Text "Style")
                , ("class", Text class)
                , ("value", Doc.toJson doc)
                ]
        Anchor identifier doc ->
            Object
                [ ("tag", Text "Anchor")
                , ("identifier", Text identifier)
                , ("value", Doc.toJson doc)
                ]
        Tooltip doc hint ->
            Object
                [ ("tag", Text "Tooltip")
                , ("hint", Doc.toJson hint)
                , ("value", Doc.toJson doc)
                ]
        NamedLink doc url ->
            Object
                [ ("tag", Text "NamedLink")
                , ("url", Doc.toJson url)
                , ("value", Doc.toJson doc)
                ]
        Folded folded title doc ->
            Object
                [ ("tag", Text "Folded")
                , ("folded", Json.Boolean folded)
                , ("title", Doc.toJson title)
                , ("value", Doc.toJson doc)
                ]
        Callout None doc ->
            Object
                [ ("tag", Text "Callout")
                , ("icon", Object [("tag", Text "Optional"), ("kind", Text "None")])
                , ("value", Doc.toJson doc)
                ]
        Callout (Some icon) doc ->
            Object
                [ ("tag", Text "Callout")
                , ("icon", Object [("tag", Text "Optional"), ("kind", Text "Some"), ("value", Doc.toJson icon)])
                , ("value", Doc.toJson doc)
                ]
        Image doc url None ->
            Object
                [ ("tag", Text "Image")
                , ("url", Doc.toJson url)
                , ("caption", Object [("tag", Text "Optional"), ("kind", Text "None")])
                , ("value", Doc.toJson doc)
                ]
        Image doc url (Some caption) ->
            Object
                [ ("tag", Text "Image")
                , ("url", Doc.toJson url)
                , ("caption", Object [("tag", Text "Optional"), ("kind", Text "Some"), ("value", Doc.toJson caption)])
                , ("value", Doc.toJson doc)
                ]
        Paragraph paragraphs ->
            Object
                [ ("tag", Text "Paragraph")
                , ("value",
                    paragraphs
                        |> List.map Doc.toJson
                        |> Array)
                ]
        BulletedList items ->
            Object
                [ ("tag", Text "BulletedList")
                , ("value",
                    items
                        |> List.map Doc.toJson
                        |> Array)
                ]
        Join items ->
            Object
                [ ("tag", Text "Join")
                , ("value",
                    items
                        |> List.map Doc.toJson
                        |> Array)
                ]
        UntitledSection items ->
            Object
                [ ("tag", Text "UntitledSection")
                , ("value",
                    items
                        |> List.map Doc.toJson
                        |> Array)
                ]
        Column items ->
            Object
                [ ("tag", Text "Column")
                , ("value",
                    items
                        |> List.map Doc.toJson
                        |> Array)
                ]
        NumberedList index items ->
            Object
                [ ("tag", Text "NumberedList")
                , ("index", Number (Nat.toText index))
                , ("value",
                    items
                        |> List.map Doc.toJson
                        |> Array)
                ]
        Section title items ->
            Object
                [ ("tag", Text "Section")
                , ("title", Doc.toJson title)
                , ("value",
                    items
                        |> List.map Doc.toJson
                        |> Array)
                ]
        Special _ ->
            Object
                [ ("tag", Text "Special")
                , ("comment", Text "as of yet unsupported")
                ]
        Doc.Table items ->
            Object
                [ ("tag", Text "Table")
                , ("value",
                    items
                        |> List.map (row -> List.map Doc.toJson row |> Array)
                        |> Array)
                ]
        Word text -> 
            Object
                [ ("tag", Text "Word")
                , ("value", Text text) 
                ]



test> Doc.toJson.tableTest = test.verify do
    toJsonShouldProduce (Table [
        [Word "header 1", Word "header 2"],
        [Word "row 1 / value 1", Word "row 1 / value 2"],
        [Word "row 2 / value 1", Word "row 2 / value 2"]
    ])
        """
            {
                "tag" : "Table",
                "value": [
                    [{"tag": "Word", "value": "header 1"}, {"tag": "Word", "value": "header 2"}],
                    [{"tag": "Word", "value": "row 1 / value 1"}, {"tag": "Word", "value": "row 1 / value 2"}],
                    [{"tag": "Word", "value": "row 2 / value 1"}, {"tag": "Word", "value": "row 2 / value 2"}]
                ]
            }
        """

