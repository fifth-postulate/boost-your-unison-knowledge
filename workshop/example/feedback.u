Doc.toJson.tests.harness.toJsonShouldProduce : Doc -> Text ->{Exception} ()
Doc.toJson.tests.harness.toJsonShouldProduce subject expectedSource =
    actual = Doc.toJson subject
    expected = Json.fromText expectedSource

    ensureEqual actual expected

