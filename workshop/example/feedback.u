feedback.logic.receive : OrderedTable Instant Doc -> '{Route, Remote, Exception} ()
feedback.logic.receive table =
  do
    noCapture POST (s "feedback")
    match 
      catch do
        text = bodyUtf8()
        Json.fromText text
     with
      Right json ->
        match Doc.fromJson json with
          Right doc ->
            tick = Remote.now()
            OrderedTable.write table tick doc
            ok.json
              (Object
                [ ("state", Text "successful")
                , ("message", Text "Thank you for your feedback")
                ])
          Left failure -> raiseBadRequest "failed to parse Doc" failure
      Left failure -> raiseBadRequest "failed to parse json" failure

-- The definitions below no longer typecheck with the changes above.
-- Please fix the errors and try `update` again.

feedback.deploy : '{IO, Exception} URI
feedback.deploy = Cloud.main do
    environment = Environment.default()
    database = Database.named "booster-feedback"
    Database.assign database environment
    table = OrderedTable.named database "feedback-documents" instantOrdering
    serviceHash = deployHttp environment (Route.run (feedback.logic table))
    ServiceName.assign (ServiceName.named "booster-unison-feedback") serviceHash

feedback.instantOrdering : Instant -> Instant -> Ordering
feedback.instantOrdering left right =
    if left < right then
        Less
    else if right > left then
        Greater
    else
        Equal


feedback.logic : OrderedTable Instant Doc -> '{Route, Remote, Exception} ()
feedback.logic table =
  use Route <|>
  logic.info <|> (logic.receive table)



