---

{{
    Determines the [greatest common divisor](https://en.wikipedia.org/wiki/Greatest_common_divisor)
    of two {type Nat}ural numbers.

    ```
        (gcd, _, _) = egcd 37 51
        gcd
    ```

    The two {type Int}egers returned can be used to represent the greatest
    common divisor as a sum of the inputs

    ```
        (_, a, b) = egcd 37 51

        (a * (Nat.toInt 37) + b * (Nat.toInt 51), a, b)  
    ```
}}
egcd : Nat -> Nat -> (Nat, Int, Int)
egcd u v =
    -- contract: a = p*u + q*v, b = r*u + s*v
    go : Nat -> Nat -> Int -> Int -> Int -> Int -> (Nat, Int, Int)
    go a b p q r s =
        if b == 0 then
            (a, p, q)
        else
            quotient =
                a / b
                    |> Nat.toInt
            go b (a%b) r s (p - quotient * r) (q - quotient * s)
    go u v +1 +0 +0 +1
